{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "qfq",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "base_assignment"
        },
        {
          "type": "SYMBOL",
          "name": "level_assignment"
        },
        {
          "type": "SYMBOL",
          "name": "block_start"
        },
        {
          "type": "SYMBOL",
          "name": "block_end"
        },
        {
          "type": "SYMBOL",
          "name": "value_line"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment_content"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "comment_content": {
      "type": "PATTERN",
      "value": "[^\\r\\n]*"
    },
    "base_assignment": {
      "type": "PREC",
      "value": 5,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "keyword",
            "content": {
              "type": "SYMBOL",
              "name": "base_keyword"
            }
          },
          {
            "type": "STRING",
            "value": "="
          },
          {
            "type": "FIELD",
            "name": "value",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "value"
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "base_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "form"
        },
        {
          "type": "STRING",
          "value": "r"
        },
        {
          "type": "STRING",
          "value": "dbIndex"
        },
        {
          "type": "STRING",
          "value": "debugShowBodyText"
        },
        {
          "type": "STRING",
          "value": "sqlLog"
        },
        {
          "type": "STRING",
          "value": "sqlLogMode"
        },
        {
          "type": "STRING",
          "value": "render"
        },
        {
          "type": "STRING",
          "value": "performanceReport"
        }
      ]
    },
    "level_assignment": {
      "type": "PREC",
      "value": 5,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "FIELD",
                    "name": "level_path",
                    "content": {
                      "type": "SYMBOL",
                      "name": "level_path"
                    }
                  },
                  {
                    "type": "STRING",
                    "value": "."
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "FIELD",
            "name": "keyword",
            "content": {
              "type": "SYMBOL",
              "name": "level_keyword"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "bracket_suffix"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "STRING",
            "value": "="
          },
          {
            "type": "FIELD",
            "name": "value",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "value"
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "level_path": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "level_identifier"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "."
                },
                {
                  "type": "SYMBOL",
                  "name": "level_identifier"
                }
              ]
            }
          }
        ]
      }
    },
    "level_identifier": {
      "type": "PATTERN",
      "value": "[\\w-]+"
    },
    "bracket_suffix": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "\\d+"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "level_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "fbeg"
        },
        {
          "type": "STRING",
          "value": "fend"
        },
        {
          "type": "STRING",
          "value": "fsep"
        },
        {
          "type": "STRING",
          "value": "fskipwrap"
        },
        {
          "type": "STRING",
          "value": "shead"
        },
        {
          "type": "STRING",
          "value": "stail"
        },
        {
          "type": "STRING",
          "value": "head"
        },
        {
          "type": "STRING",
          "value": "tail"
        },
        {
          "type": "STRING",
          "value": "lbeg"
        },
        {
          "type": "STRING",
          "value": "lend"
        },
        {
          "type": "STRING",
          "value": "libeg"
        },
        {
          "type": "STRING",
          "value": "liend"
        },
        {
          "type": "STRING",
          "value": "rbeg"
        },
        {
          "type": "STRING",
          "value": "rbgd"
        },
        {
          "type": "STRING",
          "value": "rend"
        },
        {
          "type": "STRING",
          "value": "renr"
        },
        {
          "type": "STRING",
          "value": "rsep"
        },
        {
          "type": "STRING",
          "value": "sql"
        },
        {
          "type": "STRING",
          "value": "twig"
        },
        {
          "type": "STRING",
          "value": "althead"
        },
        {
          "type": "STRING",
          "value": "altsql"
        },
        {
          "type": "STRING",
          "value": "content"
        },
        {
          "type": "STRING",
          "value": "fireIf"
        },
        {
          "type": "STRING",
          "value": "fireSubIf"
        },
        {
          "type": "STRING",
          "value": "function"
        }
      ]
    },
    "block_start": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "block_name"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "block_name": {
      "type": "PATTERN",
      "value": "\\d+"
    },
    "block_end": {
      "type": "STRING",
      "value": "}"
    },
    "value_line": {
      "type": "PREC",
      "value": -1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "value"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "value": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "_value_part"
      }
    },
    "_value_part": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "qfq_variable"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "punctuation"
        }
      ]
    },
    "qfq_variable": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{{"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "variable_prefix"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "variable_name"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "variable_modifiers"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}}"
        }
      ]
    },
    "variable_prefix": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "&"
        },
        {
          "type": "STRING",
          "value": "!"
        }
      ]
    },
    "variable_name": {
      "type": "PATTERN",
      "value": "[\\w._-]+"
    },
    "variable_modifiers": {
      "type": "REPEAT1",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "modifier_value"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "modifier_value": {
      "type": "PATTERN",
      "value": "[^:}]+"
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "single_quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "double_quoted_string"
        }
      ]
    },
    "single_quoted_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "'"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^'\\\\\\r\\n]+"
              },
              {
                "type": "PATTERN",
                "value": "\\\\."
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "'"
        }
      ]
    },
    "double_quoted_string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^\"\\\\\\r\\n]+"
              },
              {
                "type": "PATTERN",
                "value": "\\\\."
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "number": {
      "type": "PATTERN",
      "value": "-?\\d+(\\.\\d+)?"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "operator": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "<="
        },
        {
          "type": "STRING",
          "value": ">="
        },
        {
          "type": "STRING",
          "value": "<>"
        },
        {
          "type": "STRING",
          "value": "!="
        },
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "STRING",
          "value": "+"
        },
        {
          "type": "STRING",
          "value": "-"
        },
        {
          "type": "STRING",
          "value": "*"
        },
        {
          "type": "STRING",
          "value": "/"
        },
        {
          "type": "STRING",
          "value": "%"
        },
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "STRING",
          "value": "&"
        }
      ]
    },
    "punctuation": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "STRING",
          "value": ")"
        },
        {
          "type": "STRING",
          "value": ";"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}